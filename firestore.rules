rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Users ──────────────────────────────────────────────────────────────
    // Users can only read/write their own profile document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ─── Teams ──────────────────────────────────────────────────────────────
    // Members can read their team; only owner can update membership
    match /teams/{teamId} {
      allow read: if request.auth != null &&
        request.auth.token.email in resource.data.members;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.ownerId;

      // Call logs sub-collection: team members can read/write
      match /call_logs/{logId} {
        allow read, create: if request.auth != null &&
          request.auth.token.email in
            get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }
    }

    // ─── Leads ──────────────────────────────────────────────────────────────
    match /leads/{leadId} {
      // Helper functions
      function isTeamMember() {
        let teamId = resource.data.teamId;
        return teamId != null &&
          request.auth.token.email in
            get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }

      function isOwner() {
        let teamId = resource.data.teamId;
        return teamId != null &&
          request.auth.uid ==
            get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId;
      }

      // Read: own leads OR team member
      allow read: if request.auth != null &&
        (resource.data.addedBy == request.auth.uid || isTeamMember());

      // Create: any authenticated user can create a lead
      allow create: if request.auth != null &&
        request.resource.data.addedBy == request.auth.uid;

      // Update: own leads OR team members (for claiming and status changes)
      allow update: if request.auth != null &&
        (resource.data.addedBy == request.auth.uid || isTeamMember());

      // Delete: only the creator or team owner can delete
      allow delete: if request.auth != null &&
        (resource.data.addedBy == request.auth.uid || isOwner());
    }
  }
}
